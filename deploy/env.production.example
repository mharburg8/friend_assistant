# ORACLE Production Environment (AWS HIPAA Server)
# Copy to .env.production and fill in values

# === Database (self-hosted PostgreSQL) ===
DATABASE_URL=postgresql://oracle:CHANGE_THIS_PASSWORD@postgres:5432/oracle
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# === Claude via AWS Bedrock (HIPAA-compliant) ===
CLAUDE_PROVIDER=bedrock
AWS_REGION=us-east-2
# If running on EC2 with IAM role, no keys needed.
# Otherwise uncomment:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# === Auth (self-hosted mode) ===
AUTH_MODE=self-hosted
AUTH_SECRET=GENERATE_A_RANDOM_64_CHAR_STRING_HERE
ORACLE_OWNER_USER_ID=will-be-set-after-first-login

# === Signal Messenger ===
SIGNAL_API_URL=http://signal-api:8080
SIGNAL_PHONE_NUMBER=+1XXXXXXXXXX
MARK_PHONE_NUMBER=+1XXXXXXXXXX

# === Retell AI (Voice — optional) ===
# RETELL_API_KEY=your-retell-api-key
# RETELL_AGENT_ID=your-agent-id

# === App ===
NEXT_PUBLIC_APP_URL=https://oracle.harburgautomation.com
NODE_ENV=production

# === Supabase (leave empty for self-hosted mode) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
