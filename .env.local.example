# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic (direct API — for development)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude Provider: "anthropic" (default) or "bedrock" (HIPAA-compliant)
# CLAUDE_PROVIDER=bedrock

# AWS Bedrock (only needed if CLAUDE_PROVIDER=bedrock)
# AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Twilio (SMS — two-way texting with Claude)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# MARK_PHONE_NUMBER=+1xxxxxxxxxx

# Retell AI (Voice — real-time voice + outbound calls)
# RETELL_API_KEY=your-retell-api-key
# RETELL_AGENT_ID=your-agent-id
# RETELL_PHONE_NUMBER=+1xxxxxxxxxx

# Owner user ID (your Supabase auth.users UUID — set after first login)
# ORACLE_OWNER_USER_ID=your-uuid

NEXT_PUBLIC_APP_URL=http://localhost:3000

# S3 File Storage (HIPAA-compliant)
AWS_S3_BUCKET=oracle-attachments-prod

# Computer Use Agent (Ubuntu server with Xvfb + Claude computer use)
# COMPUTER_AGENT_URL=http://3.138.91.167:8585
# COMPUTER_AGENT_API_KEY=your-secret-agent-key
